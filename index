let currentSection=null, currentSongIndex=0, doneSongs={};

function showView(id){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

function openSection(sec){
  currentSection=sec;
  doneSongs[sec]=doneSongs[sec]||{};
  const isMisa=sec==='misa';
  document.getElementById('list-title').textContent=isMisa?'Santa Misa':'Adoración Eucarística';
  document.getElementById('list-subtitle').textContent=isMisa?'Hora Santa · Pascua Juvenil 2026':'Santísimo · Pascua Juvenil 2026';
  document.getElementById('progress-fill').className='progress-fill '+(isMisa?'pf-misa':'pf-adoracion');
  renderSongList();
  showView('song-list');
  updateProgress();
}

function renderSongList(){
  const songs=SONGS[currentSection],isMisa=currentSection==='misa',done=doneSongs[currentSection]||{};
  document.getElementById('songs-container').innerHTML=songs.map((s,i)=>`
    <div class="song-item ${done[i]?'done':''}" onclick="openSong(${i})">
      <span class="song-num">${i+1}</span>
      <div class="song-info">
        <p class="song-title-sm">${s.title}</p>
        <p class="song-artist-sm">${s.artist}</p>
      </div>
      <span class="song-badge ${isMisa?'badge-misa':'badge-adoracion'}">${s.badge}</span>
      <div class="song-check">${done[i]?'✓':''}</div>
    </div>`).join('');
}

function updateProgress(){
  const songs=SONGS[currentSection],done=Object.keys(doneSongs[currentSection]||{}).length,pct=(done/songs.length)*100;
  document.getElementById('progress-fill').style.width=pct+'%';
  document.getElementById('progress-label').textContent=done+' de '+songs.length+' vistos';
}

function openSong(index){
  currentSongIndex=index;
  const song=SONGS[currentSection][index],isMisa=currentSection==='misa';
  document.getElementById('view-title').textContent=song.title;
  document.getElementById('view-artist').textContent=song.artist;
  const badge=document.getElementById('view-badge');
  badge.textContent=song.badge.toUpperCase();
  badge.className='song-badge-view '+(isMisa?'badge-misa':'badge-adoracion');
  document.getElementById('song-counter').textContent=(index+1)+' / '+SONGS[currentSection].length;
  document.getElementById('prev-btn').disabled=index===0;
  const nb=document.getElementById('next-btn');
  nb.disabled=index===SONGS[currentSection].length-1;
  nb.className='nav-btn '+(isMisa?'next-misa':'next-adoracion');
  const body=document.getElementById('lyrics-body');
  body.innerHTML=song.lyrics;
  body.scrollTop=0;
  document.getElementById('read-progress-fill').className='read-progress-fill '+(isMisa?'rpf-misa':'rpf-adoracion');
  document.getElementById('read-progress-fill').style.width='0%';
  updateMarkBtn();
  document.getElementById('mark-cta').classList.add('visible');
  showView('song-view');
}

function updateMarkBtn(){
  const isMisa=currentSection==='misa',isDone=!!(doneSongs[currentSection]&&doneSongs[currentSection][currentSongIndex]);
  const btn=document.getElementById('mark-btn'),label=document.getElementById('mark-btn-label'),icon=document.getElementById('mark-btn-icon');
  if(isDone){
    btn.className='mark-btn mb-done';
    label.textContent='Cantado ✓';
    icon.textContent='✓';
  }else{
    btn.className='mark-btn '+(isMisa?'mb-misa':'mb-adoracion');
    label.textContent='Marcar como cantado';
    icon.textContent='♪';
  }
}

function toggleDone(){
  doneSongs[currentSection]=doneSongs[currentSection]||{};
  doneSongs[currentSection][currentSongIndex]=true;
  updateMarkBtn();
  updateProgress();
}

function onLyricsScroll(){
  const el=document.getElementById('lyrics-body'),s=el.scrollHeight-el.clientHeight;
  if(s<=0)return;
  const pct=Math.min(100,(el.scrollTop/s)*100);
  document.getElementById('read-progress-fill').style.width=pct+'%';
  if(pct>=88&&!(doneSongs[currentSection]&&doneSongs[currentSection][currentSongIndex])){
    doneSongs[currentSection]=doneSongs[currentSection]||{};
    doneSongs[currentSection][currentSongIndex]=true;
    updateMarkBtn();
    updateProgress();
  }
}

function prevSong(){
  if(currentSongIndex>0)openSong(currentSongIndex-1);
}

function nextSong(){
  if(currentSongIndex<SONGS[currentSection].length-1)openSong(currentSongIndex+1);
}

function goList(){
  renderSongList();
  updateProgress();
  document.getElementById('mark-cta').classList.remove('visible');
  showView('song-list');
}

function goHome(){
  document.getElementById('mark-cta').classList.remove('visible');
  showView('splash');
}

let touchX=0;
document.getElementById('song-view').addEventListener('touchstart',e=>{touchX=e.touches[0].clientX;},{passive:true});
document.getElementById('song-view').addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-touchX;
  if(Math.abs(dx)>55){if(dx<0)nextSong();else prevSong();}
});
</script>

</body>
</html>
